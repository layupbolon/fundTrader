# E2E runtime
NODE_ENV=test
PORT=3000

# Auth
JWT_SECRET=e2e_jwt_secret_at_least_32_characters

# Database (recommended: dedicated e2e db)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fundtrader_e2e

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
MASTER_KEY=e2e_master_key_at_least_32_characters_long
ENCRYPTION_SALT=e2e_salt_at_least_16_chars

# E2E switches
SCHEDULER_ENABLED=false
BROKER_MOCK=true
TELEGRAM_POLLING_ENABLED=false

# Frontend -> backend proxy target for Playwright web tests
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
