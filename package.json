{
  "name": "fundtrader-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A-share fund automated trading platform - Monorepo",
  "scripts": {
    "dev": "pnpm --filter @fundtrader/backend start:dev",
    "dev:frontend": "pnpm --filter @fundtrader/frontend dev",
    "dev:all": "pnpm --filter @fundtrader/backend start:dev & pnpm --filter @fundtrader/frontend dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @fundtrader/backend build",
    "build:shared": "pnpm --filter @fundtrader/shared build",
    "build:frontend": "pnpm --filter @fundtrader/frontend build",
    "start": "pnpm --filter @fundtrader/backend start",
    "start:prod": "pnpm --filter @fundtrader/backend start:prod",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter @fundtrader/backend test",
    "test:cov": "pnpm --filter @fundtrader/backend test:cov",
    "test:e2e:seed": "pnpm --filter @fundtrader/backend test:e2e:seed",
    "test:e2e:api": "pnpm --filter @fundtrader/backend test:e2e",
    "test:e2e:web": "pnpm test:e2e:seed && pnpm --filter @fundtrader/frontend test:e2e",
    "test:e2e": "pnpm test:e2e:api && pnpm test:e2e:web",
    "test:e2e:pr": "pnpm --filter @fundtrader/backend test:e2e:pr && pnpm test:e2e:seed && pnpm --filter @fundtrader/frontend test:e2e:pr",
    "test:e2e:nightly": "pnpm --filter @fundtrader/backend test:e2e:nightly && pnpm test:e2e:seed && pnpm --filter @fundtrader/frontend test:e2e:nightly",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "dcup": "cd packages/backend && docker-compose up -d",
    "dcdown": "cd packages/backend && docker-compose down"
  },
  "keywords": [
    "fund",
    "trading",
    "automation",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "typescript": "^5.9.3"
  }
}
