{
  "name": "@fundtrader/backend",
  "version": "1.0.0",
  "description": "A-share fund automated trading platform backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/main.ts",
    "start:dev": "nodemon --watch src --exec ts-node src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "pnpm run test:typecheck && vitest run -c vitest.config.ts",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test:watch": "vitest -c vitest.config.ts",
    "test:cov": "vitest run -c vitest.config.ts --coverage",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "test:e2e:pr": "vitest run -c vitest.e2e.config.ts test/e2e/api/smoke",
    "test:e2e:nightly": "vitest run -c vitest.e2e.config.ts",
    "test:e2e:seed": "ts-node test/e2e/seed.ts",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "deploy:preflight": "ts-node --transpile-only scripts/preflight-check.ts",
    "backup:verify": "ts-node --transpile-only scripts/verify-backup-restore.ts",
    "migrate:backtest-user-id": "ts-node --transpile-only scripts/migrate-backtest-user-id.ts"
  },
  "keywords": [
    "fund",
    "trading",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fundtrader/shared": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.1",
    "node-telegram-bot-api": "^0.67.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "puppeteer": "^24.37.5",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.14",
    "@swc/core": "^1.15.32",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^3.15.9",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  }
}
